# Tushare
TUSHARE_TOKEN=your_token_here

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=quant_db
MYSQL_SOCKET=/tmp/mysql.sock

# 飞书告警
FEISHU_WEBHOOK=

# 企业微信
WECOM_WEBHOOK=

# 邮件通知 (QQ邮箱SMTP)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# 阿里云短信
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_ACCESS_SECRET=
ALIYUN_SMS_SIGN_NAME=智能量化
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx

# 阿里云行情
ALIYUN_APP_CODE=

# CORS
CORS_ORIGINS=http://localhost:5001

# 日志
LOG_LEVEL=INFO

# ========== 交易模式 (实盘相关) ==========
# 交易模式: sim(模拟) / live(实盘)
TRADE_MODE=sim

# 同花顺/easytrader 配置 (live 模式需要)
TRADE_BROKER=ths           # ths(同花顺) / eastmoney(东方财富)
TRADE_ACCOUNT_ID=
TRADE_PASSWORD=
TRADE_COMM_PASSWORD=

# 实盘安全控制
MAX_DAILY_LOSS_PCT=-5     # 单日最大亏损 -5% 熔断
MAX_SINGLE_ORDER_AMOUNT=50000  # 单笔最大下单金额
MAX_POSITION_PCT=30       # 单股最大仓位 30%
PRICE_DEVIATION_PCT=1.0   # 下单价 vs 市价偏差允许范围 (%)
ENABLE_REAL_TRADING=false  # 安全开关: 必须显式设为 true 才开实盘

# 远程交易服务端配置（macOS 用 Windows VM 跑同花顺时配置）
REMOTE_TRADER_HOST=192.168.1.100   # Windows VM IP 地址
REMOTE_TRADER_PORT=1430            # easytrader server 端口（默认 1430）
